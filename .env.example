# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=jobhunt
POSTGRES_USER=jobhunt
POSTGRES_PASSWORD=changeme_strong_password

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth ─────────────────────────────────────────────────────────────────────
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7
JWT_EXPIRE_DAYS_REMEMBER_ME=30

# ── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ── Admin seed ───────────────────────────────────────────────────────────────
ADMIN_EMAIL=praveenp.1118@gmail.com
ADMIN_INITIAL_PASSWORD=

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Platform API keys (for Wallet plan users) ────────────────────────────────
PLATFORM_ANTHROPIC_API_KEY=
PLATFORM_APIFY_TOKEN=

# ── Apify ────────────────────────────────────────────────────────────────────
APIFY_TOKEN=

# ── Gmail (job search account) ───────────────────────────────────────────────
GMAIL_ADDRESS=praveenp.1118@gmail.com
GMAIL_APP_PASSWORD=

# ── Personal notification email ──────────────────────────────────────────────
NOTIFICATION_EMAIL=praveen.prakash.82@gmail.com

# ── Encryption (for stored credentials) ─────────────────────────────────────
FERNET_KEY=changeme_generate_with_python_cryptography_fernet

# ── Storage ──────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
# For S3 (V2):
# STORAGE_BACKEND=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION=ap-south-1

# ── Razorpay (Wallet plan) ───────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── App ──────────────────────────────────────────────────────────────────────
ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ── Legal pages (GitHub Pages serves from /docs, so no "/docs" in the URL) ─────
PRIVACY_POLICY_URL=https://praveenp1118.github.io/JobHunt/privacy.html
TERMS_URL=https://praveenp1118.github.io/JobHunt/terms.html
COOKIES_URL=https://praveenp1118.github.io/JobHunt/cookies.html

# ── Scoring thresholds ───────────────────────────────────────────────────────
S1_MIN_THRESHOLD=65
S3_BLOCK_THRESHOLD=85
S3_REVIEW_THRESHOLD=90

# ── Scheduler ────────────────────────────────────────────────────────────────
WEEKLY_SCAN_CRON=30 17 * * 0
GMAIL_POLL_INTERVAL_MINUTES=60
GHOST_AFTER_DAYS=28
