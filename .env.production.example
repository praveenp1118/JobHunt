# ─────────────────────────────────────────────────────────────────────────────
# JobHunt — PRODUCTION environment template.
# Copy to .env.production and fill in real secrets. NEVER commit .env.production.
# Deploy reads this via:  docker-compose -f docker-compose.prod.yml --env-file .env.production ...
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
# ENV controls REAL email sending. Keep "test" so all outbound application/HITL
# email is redirected to NOTIFICATION_EMAIL. Set to "production" ONLY when you
# intend JobHunt to send real emails to recruiters. Leave as "test" until verified.
ENV=test
FRONTEND_URL=https://aijobshunt.com
BACKEND_URL=https://aijobshunt.com

# Daily auto-enrich cron for HIGH-SCORING partial-JD jobs (Bright Data collect-by-URL).
# Opt-in per user (Settings). These are the global knobs — tunable without a code change.
PARTIAL_ENRICH_ENABLED=true        # global kill-switch for the cron
PARTIAL_ENRICH_CAP=20              # HARD ceiling of jobs enriched per user per run
PARTIAL_ENRICH_CRON=0 3 * * *      # daily 03:00 UTC (m h dom mon dow)

# Google Analytics 4 Measurement ID for the public landing page (G-XXXXXXXXXX).
# Embedded into the frontend at BUILD time via the docker-compose build arg — a
# change requires `up -d --build`. Leave blank to disable analytics.
VITE_GA_ID=

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=jobhunt
POSTGRES_USER=jobhunt
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
# DATABASE_URL is derived by docker-compose.prod.yml from POSTGRES_* (host = db);
# this value is a fallback for tooling run outside compose.
DATABASE_URL=postgresql+asyncpg://jobhunt:CHANGE_ME_strong_db_password@db:5432/jobhunt

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth ─────────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7
JWT_EXPIRE_DAYS_REMEMBER_ME=30

# ── Encryption (AES/Fernet for stored user credentials) ──────────────────────
FERNET_KEY=CHANGE_ME_python_cryptography_fernet_generate_key

# ── Admin seed ───────────────────────────────────────────────────────────────
ADMIN_EMAIL=you@example.com
ADMIN_INITIAL_PASSWORD=CHANGE_ME_admin_password

# ── Google OAuth (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://aijobshunt.com/auth/google/callback

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# Platform fallback keys (used for Wallet-plan users who don't bring their own)
PLATFORM_ANTHROPIC_API_KEY=
PLATFORM_APIFY_TOKEN=

# ── Apify ────────────────────────────────────────────────────────────────────
APIFY_TOKEN=

# ── Gmail (job-search account: IMAP poll + SMTP send) ────────────────────────
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
# Where test-mode email is redirected (and where HITL/notifications are sent)
NOTIFICATION_EMAIL=

# ── Storage ──────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
# For S3 (planned):
# STORAGE_BACKEND=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION=ap-south-1

# ── Stripe (JobHunt Pro subscription) ────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# ── Razorpay (JobHunt Pro subscription — parallel to Stripe; TEST keys for now) ─
RAZORPAY_KEY_ID=            # rzp_test_… now; rzp_live_… only at live cutover
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=    # from the Razorpay Dashboard → Webhooks
RAZORPAY_PLAN_ID=          # plan_… from: python -m app.scripts.create_razorpay_plan

# Active billing provider for NEW subscriptions: stripe | razorpay
# Keep 'stripe' until Razorpay is approved + E2E-tested, then flip to 'razorpay'.
PAYMENT_PROVIDER=stripe

# ── Legal pages (served same-origin by the frontend nginx: /privacy, /terms, /cookies) ──
PRIVACY_POLICY_URL=https://aijobshunt.com/privacy
TERMS_URL=https://aijobshunt.com/terms
COOKIES_URL=https://aijobshunt.com/cookies

# ── Scoring thresholds ───────────────────────────────────────────────────────
S1_MIN_THRESHOLD=65
S3_BLOCK_THRESHOLD=85
S3_REVIEW_THRESHOLD=90

# ── Scheduler ────────────────────────────────────────────────────────────────
WEEKLY_SCAN_CRON=30 17 * * 0
GMAIL_POLL_INTERVAL_MINUTES=60
GHOST_AFTER_DAYS=28
