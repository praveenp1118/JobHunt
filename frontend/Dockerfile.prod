# ── Build stage: compile the Vite app to static assets ──
FROM node:20-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
# The app calls the API at the relative path /api (same-origin), so no build-time
# API URL is needed — Caddy routes /api/* to the backend in production.
RUN npm run build

# ── Serve stage: nginx serving the static build ──
FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
