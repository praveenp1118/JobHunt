# Frontend build-time env (Vite). Copy to `frontend/.env` and fill in.
# Only VITE_-prefixed vars are exposed to the client, and they are embedded at
# BUILD time (changing one requires a rebuild, not just a restart).

# Google Analytics 4 Measurement ID for the public landing page (format G-XXXXXXXXXX).
# Leave blank to disable analytics — src/lib/analytics.js becomes a no-op.
VITE_GA_ID=
